# Copy this file to `.env` and paste your secret values.
# `.env` is gitignored — never commit it.
#
# On Render: add the same variables under your Web Service → Environment
# (e.g. OPENAI_API_KEY). Do not put API keys in the repo or in render.yaml.

# --- Existing doc generation (doc_generator.py) ---
OPENAI_API_KEY=

# --- LLM factory (llm_factory.py) ---
# Chat model provider: openai | anthropic | llama (future) | gemini (future)
LLM_PROVIDER=openai
# Model name for the selected LLM provider (defaults per provider if unset)
LLM_MODEL=gpt-4o-mini

# Embedding provider: openai | local
EMBEDDING_PROVIDER=openai
# Embedding model (OpenAI model id or HuggingFace model for local/BGE)
EMBEDDING_MODEL=text-embedding-3-small

# Provider API keys (set only what you use)
ANTHROPIC_API_KEY=
# LLAMA_API_KEY=
# GOOGLE_API_KEY=

# --- Vector index (vector_index.py) ---
# Local dev: chroma (default). Cloud/Render: pinecone
# VECTOR_STORE_PROVIDER=chroma
# CHROMA_PERSIST_DIR=.chroma
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=documind

# --- Vector search (vector_search.py) ---
# VECTOR_HYBRID_ENABLED=true
# VECTOR_HYBRID_ALPHA=0.5
# VECTOR_RERANK_ENABLED=false
# VECTOR_RERANK_TOP_N=20
# VECTOR_RERANK_MODE=lexical

# --- Code graph (code_graph.py) ---
# GRAPH_PERSIST_DIR=.graph_store

# --- LangSmith tracing (tracing.py) ---
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=
# LANGCHAIN_PROJECT=documind

# --- Evaluation harness (eval/run_eval.py) ---
# Agent answer model (separate from the RAGAS judge below)
# LLM_MODEL=gpt-4o-mini
# RAGAS_JUDGE_MODEL=gpt-4o-mini
# RAGAS_JUDGE_EMBEDDING_MODEL=text-embedding-3-small
# Optional alias accepted by LangChain tracing:
# LANGCHAIN_API_KEY=
