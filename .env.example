# Copy this file to `.env` and paste your secret values.
# `.env` is gitignored — never commit it.
#
# On Render: add the same variables under your Web Service → Environment
# (e.g. OPENAI_API_KEY). Do not put API keys in the repo or in render.yaml.

# --- Existing doc generation (doc_generator.py) ---
OPENAI_API_KEY=

# --- LLM factory (llm_factory.py) ---
# Chat model provider: openai | anthropic | llama (future) | gemini (future)
LLM_PROVIDER=openai
# Model name for the selected LLM provider (defaults per provider if unset)
LLM_MODEL=gpt-4o-mini

# Embedding provider: openai | local
EMBEDDING_PROVIDER=openai
# Embedding model (OpenAI model id or HuggingFace model for local/BGE)
EMBEDDING_MODEL=text-embedding-3-small

# Provider API keys (set only what you use)
ANTHROPIC_API_KEY=
# LLAMA_API_KEY=
# GOOGLE_API_KEY=
